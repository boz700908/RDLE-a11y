            shouldBeVisible = _form.EvaluateEnableIf(prop);
            Assert.IsFalse(shouldBeVisible, "SoundData enableIf: TestSound should be hidden when HasSound is false");
        }

        [Test]
        public void TestCharacterEnableIf_CorrectEvaluation()
        {
            // 测试 Character 类型的 enableIf
            var prop = new PropertyData
            {
                name = "TestCharacter",
                displayName = "Test Character",
                value = "",
                type = "Character",
                enableIfMethod = "UseCustomColor"
            };
            
            // 当 UseCustomColor = false 时应隐藏
            bool shouldBeVisible = _form.EvaluateEnableIf(prop);
            Assert.IsFalse(shouldBeVisible, "Character enableIf: TestCharacter should be hidden when UseCustomColor is false");

