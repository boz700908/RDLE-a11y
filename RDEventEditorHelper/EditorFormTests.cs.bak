        [Test]
        public void TestFloatExpressionEnableIf_CorrectEvaluation()
        {
            // 测试 FloatExpression 类型的 enableIf
            var prop = new PropertyData
            {
                name = "TestExpression",
                displayName = "Test Expression",
                value = "",
                type = "FloatExpression",
                enableIfMethod = "HasSound"
            };
            
            // 当 HasSound = true 时应显示
            bool shouldBeVisible = _form.EvaluateEnableIf(prop);
            Assert.IsTrue(shouldBeVisible, "FloatExpression enableIf: TestExpression should be visible when HasSound is true");

            // 设置 HasSound = false
            _testProperties.First(p => p.name == "HasSound").value = "false";
