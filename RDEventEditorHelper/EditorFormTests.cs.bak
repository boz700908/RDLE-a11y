using System;
using System.Collections.Generic;
using System.Linq;
using System.Windows.Forms;
using NUnit.Framework;

namespace RDEventEditorHelper.Tests
{
    [TestFixture]
    public class EnableIfTests
    {
        private EditorForm _form;
        private PropertyData[] _testProperties;

        [SetUp]
        public void Setup()
        {
            _form = new EditorForm();
            _testProperties = CreateTestProperties();
            _form.SetData("TestEvent", _testProperties);
        }

        private PropertyData[] CreateTestProperties()
        {
            return new PropertyData[]
            {
                new PropertyData
                {
                    name = "EnableAdvanced",
                    displayName = "Enable Advanced Options",
                    value = "false",
                    type = "Bool"
                },
                new PropertyData
                {
                    name = "AdvancedSetting",
                    displayName = "Advanced Setting",
                    value = "",
                    type = "String",
                    enableIfMethod = "EnableAdvanced"
                },
                new PropertyData
                {
                    name = "Difficulty",
                    displayName = "Difficulty",
                    value = "Normal",
                    type = "Enum",
                    options = new string[] { "Easy", "Normal", "Hard", "Expert" }
                },
                new PropertyData
                {
                    name = "SpeedMultiplier",
                    displayName = "Speed Multiplier",
                    value = "1.0",
                    type = "Float",
                    enableIfMethod = "Difficulty"
                },
                new PropertyData
                {
                    name = "Bar",
                    displayName = "Bar",
                    value = "1",
                    type = "Int"
                },
                new PropertyData
                {
                    name = "Beat",
                    displayName = "Beat",
                    value = "0",
                    type = "Int"
                },
                new PropertyData
                {
                    name = "HasSound",
                    displayName = "Has Sound",
                    value = "true",
                    type = "Bool"
                },
                new PropertyData
                {
                    name = "SoundVolume",
                    displayName = "Sound Volume",
                    value = "100",
                    type = "Float",
                    enableIfMethod = "HasSound"
                },
                new PropertyData
                {
                    name = "ColorValue",
                    displayName = "Color Value",
                    value = "#FFFFFF",
                    type = "Color",
                    enableIfMethod = "UseCustomColor"
                },
                new PropertyData
                {
                    name = "UseCustomColor",
                    displayName = "Use Custom Color",
                    value = "false",
                    type = "Bool"
                }
            };
        }

        [Test]
        public void TestBoolEnableIf_CorrectEvaluation()
        {
            // 测试 Bool 类型的 enableIf
            var prop = _testProperties.First(p => p.name == "AdvancedSetting");
            Assert.AreEqual("false", _testProperties.First(p => p.name == "EnableAdvanced").value);
            
            // 当 EnableAdvanced = false 时，AdvancedSetting 应隐藏
            bool shouldBeVisible = _form.EvaluateEnableIf(prop);
            Assert.IsFalse(shouldBeVisible, "Bool enableIf: AdvancedSetting should be hidden when EnableAdvanced is false");

            // 设置 EnableAdvanced = true
            _testProperties.First(p => p.name == "EnableAdvanced").value = "true";
            _form.ClearEnableIfCache();
            
            shouldBeVisible = _form.EvaluateEnableIf(prop);
            Assert.IsTrue(shouldBeVisible, "Bool enableIf: AdvancedSetting should be visible when EnableAdvanced is true");
        }

        [Test]
        public void TestIntEnableIf_CorrectEvaluation()
        {
            // 测试 Int 类型的 enableIf
            var prop = _testProperties.First(p => p.name == "Beat");
            prop.enableIfMethod = "Bar";
            
            // 当 Bar = 1 > 0 时应显示
            bool shouldBeVisible = _form.EvaluateEnableIf(prop);
            Assert.IsTrue(shouldBeVisible, "Int enableIf: Beat should be visible when Bar is greater than 0");

            // 设置 Bar = 0
            _testProperties.First(p => p.name == "Bar").value = "0";
            _form.ClearEnableIfCache();
            
            shouldBeVisible = _form.EvaluateEnableIf(prop);
            Assert.IsFalse(shouldBeVisible, "Int enableIf: Beat should be hidden when Bar is 0");
        }

        [Test]
        public void TestEnumEnableIf_CorrectEvaluation()
        {
            // 测试 Enum 类型的 enableIf
            var prop = _testProperties.First(p => p.name == "SpeedMultiplier");
            
            // 当 Difficulty 有值时应显示
            bool shouldBeVisible = _form.EvaluateEnableIf(prop);
            Assert.IsTrue(shouldBeVisible, "Enum enableIf: SpeedMultiplier should be visible when Difficulty has a value");

            // 设置 Difficulty = ""
            _testProperties.First(p => p.name == "Difficulty").value = "";
            _form.ClearEnableIfCache();
            
            shouldBeVisible = _form.EvaluateEnableIf(prop);
            Assert.IsFalse(shouldBeVisible, "Enum enableIf: SpeedMultiplier should be hidden when Difficulty is empty");
        }

        [Test]
        public void TestStringEnableIf_CorrectEvaluation()
        {
            // 测试 String 类型的 enableIf
            var prop = new PropertyData
            {
                name = "TestString",
                displayName = "Test String",
                value = "",
                type = "String",
                enableIfMethod = "Difficulty"
            };
            
            // 当 Difficulty 有值时应显示
            bool shouldBeVisible = _form.EvaluateEnableIf(prop);
            Assert.IsTrue(shouldBeVisible, "String enableIf: TestString should be visible when Difficulty has a value");

            // 设置 Difficulty = ""
            _testProperties.First(p => p.name == "Difficulty").value = "";
            _form.ClearEnableIfCache();
            
            shouldBeVisible = _form.EvaluateEnableIf(prop);
            Assert.IsFalse(shouldBeVisible, "String enableIf: TestString should be hidden when Difficulty is empty");
        }

