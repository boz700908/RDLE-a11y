                enableIfMethod = "SoundVolume"
            };
            
            // 当 SoundVolume = 100 > 0 时应显示
            bool shouldBeVisible = _form.EvaluateEnableIf(prop);
            Assert.IsTrue(shouldBeVisible, "Float enableIf: TestFloat should be visible when SoundVolume is greater than 0");

            // 设置 SoundVolume = 0
            _testProperties.First(p => p.name == "SoundVolume").value = "0";
            _form.ClearEnableIfCache();
            
            shouldBeVisible = _form.EvaluateEnableIf(prop);
            Assert.IsFalse(shouldBeVisible, "Float enableIf: TestFloat should be hidden when SoundVolume is 0");
        }

        [Test]
        public void TestVector2EnableIf_CorrectEvaluation()
        {
            // 测试 Vector2 类型的 enableIf
            var prop = new PropertyData
            {
                name = "TestVector2",
                displayName = "Test Vector2",
                value = "",
                type = "Vector2",
                enableIfMethod = "HasSound"
            };
            
            // 当 HasSound = true 时应显示
            bool shouldBeVisible = _form.EvaluateEnableIf(prop);
            Assert.IsTrue(shouldBeVisible, "Vector2 enableIf: TestVector2 should be visible when HasSound is true");

            // 设置 HasSound = false
            _testProperties.First(p => p.name == "HasSound").value = "false";
            _form.ClearEnableIfCache();
            
            shouldBeVisible = _form.EvaluateEnableIf(prop);
            Assert.IsFalse(shouldBeVisible, "Vector2 enableIf: TestVector2 should be hidden when HasSound is false");
        }

        [Test]
        public void TestColorEnableIf_CorrectEvaluation()
        {
            // 测试 Color 类型的 enableIf
            var prop = _testProperties.First(p => p.name == "ColorValue");
            
            // 当 UseCustomColor = false 时应隐藏
            bool shouldBeVisible = _form.EvaluateEnableIf(prop);
            Assert.IsFalse(shouldBeVisible, "Color enableIf: ColorValue should be hidden when UseCustomColor is false");

            // 设置 UseCustomColor = true
            _testProperties.First(p => p.name == "UseCustomColor").value = "true";
