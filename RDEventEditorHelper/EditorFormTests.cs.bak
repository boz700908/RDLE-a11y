            shouldBeVisible = _form.EvaluateEnableIf(prop);
            Assert.IsTrue(shouldBeVisible, "Color enableIf: ColorValue should be visible when UseCustomColor is true");
        }

        [Test]
        public void TestSoundDataEnableIf_CorrectEvaluation()
        {
            // 测试 SoundData 类型的 enableIf
            var prop = new PropertyData
            {
                name = "TestSound",
                displayName = "Test Sound",
