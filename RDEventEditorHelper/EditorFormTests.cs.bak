            Assert.IsFalse(shouldBeVisible, "FloatExpression enableIf: TestExpression should be hidden when HasSound is false");
        }

        [Test]
        public void TestInvalidEnableIfMethod_ReturnsFalse()
        {
            // 测试无效的 enableIf 方法名
            var prop = new PropertyData
            {
                name = "TestInvalid",
                displayName = "Test Invalid",
                value = "",
                type = "String",
                enableIfMethod = "NonExistentMethod"
            };
            
            bool shouldBeVisible = _form.EvaluateEnableIf(prop);
            Assert.IsFalse(shouldBeVisible, "Invalid enableIf method should return false");
        }

        [Test]
        public void TestNullEnableIfMethod_ReturnsTrue()
        {
            // 测试空的 enableIf 方法名
            var prop = new PropertyData
            {
                name = "TestNull",
                displayName = "Test Null",
                value = "",
                type = "String",
                enableIfMethod = null
            };
            
            bool shouldBeVisible = _form.EvaluateEnableIf(prop);
            Assert.IsTrue(shouldBeVisible, "Null enableIf method should return true (always visible)");
        }

        [Test]
        public void TestEmptyEnableIfMethod_ReturnsTrue()
        {
            // 测试空字符串的 enableIf 方法名
            var prop = new PropertyData
            {
                name = "TestEmpty",
                displayName = "Test Empty",
                value = "",
                type = "String",
                enableIfMethod = ""
            };
            
            bool shouldBeVisible = _form.EvaluateEnableIf(prop);
            Assert.IsTrue(shouldBeVisible, "Empty enableIf method should return true (always visible)");
        }

        [Test]
        public void TestEnableIfCache_Functionality()
        {
            // 测试缓存功能
            var prop = _testProperties.First(p => p.name == "AdvancedSetting");
            
            // 第一次评估
            bool result1 = _form.EvaluateEnableIf(prop);
            
            // 修改基础属性
            _testProperties.First(p => p.name == "EnableAdvanced").value = "true";
            _form.ClearEnableIfCache();
            
            // 第二次评估
            bool result2 = _form.EvaluateEnableIf(prop);
            
            // 验证缓存已清除
            Assert.AreNotEqual(result1, result2, "EnableIf cache should be cleared when ClearEnableIfCache is called");
        }

        [Test]
        public void TestRebuildUIForEnableIf_MaintainsValues()
        {
            // 这个测试需要更多集成测试
            Assert.Pass("RebuildUIForEnableIf test requires UI integration test");
        }

        [Test]
        public void TestOnPropertyValueChanged_UpdatesCorrectly()
        {
            // 这个测试需要更多集成测试
            Assert.Pass("OnPropertyValueChanged test requires UI integration test");
        }
    }
